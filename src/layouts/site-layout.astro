---
import { SITE_ARTICLE_TITLE_PREFIX, SITE_DESCRIPTION, SITE_DEFAULT_TITLE } from "@/site-config";

import Seo, { type OpenGraphData } from "@/components/layout/seo.astro";
import Footer from "@/components/layout/site-footer.astro";
import Header from "@/components/layout/site-header.astro";
import { CodeBlockEnhancerComponent } from "@/components/post/code-block-enhancer.component";
import { CookieConsentBannerComponent } from "@/components/feedback/cookie-consent-banner.component";
import { GlobalTooltipComponent } from "@/components/feedback/global-tooltip.component";
import { PageLoadingIndicatorComponent } from "@/components/feedback/page-loading-indicator.component";
import { PhotoSwipeToolbarComponent } from "@/components/lightbox/photo-swipe-toolbar.component";
import { ScrollTopButtonComponent } from "@/components/navigation/scroll-top-button.component";
import {
  SITE_COOKIE_NAMES,
  SITE_LEGACY_COOKIE_NAMES,
  SITE_LEGACY_STORAGE_KEYS,
  SITE_STORAGE_KEYS,
} from "@/lib/site-contracts";
import { computeRoute } from "@vercel/speed-insights";
import speedInsightsPackage from "@vercel/speed-insights/package.json";
import "@/assets/css/global.scss";

interface Props {
  locale?: string;
  title?: string;
  description?: string;
  bodyClass?: string;
  readingProgress?: boolean;
  openGraph?: OpenGraphData;
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const {
  locale = "fr",
  title,
  description,
  bodyClass,
  readingProgress = true,
  openGraph,
} = Astro.props as Props;

const seoTitle = title ? `${SITE_ARTICLE_TITLE_PREFIX} ${title}` : SITE_DEFAULT_TITLE;
const seoDescription = description ?? SITE_DESCRIPTION;
const themeStorageKey = SITE_STORAGE_KEYS.themePreference;
const legacyThemeStorageKey = SITE_LEGACY_STORAGE_KEYS.themePreference;
const detailStorageKey = SITE_STORAGE_KEYS.homeDetailView;
const legacyDetailStorageKey = SITE_LEGACY_STORAGE_KEYS.homeDetailView;
const detailCookieName = SITE_COOKIE_NAMES.homeDetailView;
const legacyDetailCookieName = SITE_LEGACY_COOKIE_NAMES.homeDetailView;
const isPost = Astro.url.pathname.startsWith("/posts/");
const shouldLoadSpeedInsights = import.meta.env.PROD && process.env.VERCEL === "1";
const speedInsightsRoute = computeRoute(Astro.url.pathname, Astro.params);
const speedInsightsVersion = speedInsightsPackage.version;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <script
      is:inline
      define:vars={{
        detailCookieName,
        detailStorageKey,
        legacyDetailCookieName,
        legacyDetailStorageKey,
        legacyThemeStorageKey,
        themeStorageKey,
      }}
    >
      (() => {
        try {
          const key = themeStorageKey;
          const legacyKey = legacyThemeStorageKey;
          const preferences = ["system", "light", "dark"];
          const stored = localStorage.getItem(key);
          const legacyStored = localStorage.getItem(legacyKey);
          const preference = preferences.includes(stored)
            ? stored
            : preferences.includes(legacyStored)
              ? legacyStored
              : "system";

          if (stored === null && preferences.includes(legacyStored)) {
            localStorage.setItem(key, preference);
            localStorage.removeItem(legacyKey);
          }

          const resolved =
            preference === "system"
              ? matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : preference;

          document.documentElement.dataset.theme = resolved;
          document.documentElement.dataset.themePreference = preference;
          document.documentElement.style.colorScheme = resolved;
        } catch {
          document.documentElement.dataset.theme = "light";
        }

        try {
          const readCookie = (name) => {
            const encodedName = `${encodeURIComponent(name)}=`;
            const cookie = document.cookie
              .split(";")
              .map((part) => part.trim())
              .find((part) => part.startsWith(encodedName));

            if (!cookie) return null;

            try {
              return decodeURIComponent(cookie.slice(encodedName.length));
            } catch {
              return null;
            }
          };
          const normalizeDetailView = (value) => {
            if (value === "true" || value === "detailed") return true;
            if (value === "false" || value === "compact") return false;
            return null;
          };
          const stored = localStorage.getItem(detailStorageKey);
          const legacyStored = localStorage.getItem(legacyDetailStorageKey);
          const candidates = [
            stored,
            legacyStored,
            readCookie(detailCookieName),
            readCookie(legacyDetailCookieName),
          ];
          const detailed = candidates.map(normalizeDetailView).find((value) => value !== null);

          if (stored === null && legacyStored !== null) {
            const normalizedLegacy = normalizeDetailView(legacyStored);
            if (normalizedLegacy !== null) {
              localStorage.setItem(detailStorageKey, normalizedLegacy ? "true" : "false");
              localStorage.removeItem(legacyDetailStorageKey);
            }
          }

          if (detailed) {
            document.documentElement.dataset.homeDetailView = "true";
          } else {
            delete document.documentElement.dataset.homeDetailView;
          }
        } catch {
          delete document.documentElement.dataset.homeDetailView;
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_DEFAULT_TITLE}
      href={`${Astro.site}rss.xml`}
    />
    <Seo
      title={seoTitle}
      description={seoDescription}
      canonical={canonicalUrl}
      openGraph={openGraph}
    />

    <slot name="head" />
  </head>

  <body
    class:list={[bodyClass, { "reading-progress-disabled": !readingProgress }]}
    data-reading-progress={readingProgress ? "on" : "off"}
  >
    <main class="site-main">
      <Header />
      <div id="main-content" class="site-content">
        <slot name="content" />
      </div>
    </main>
    <Footer />
    <CookieConsentBannerComponent client:idle />
    {isPost && <CodeBlockEnhancerComponent client:idle />}
    {isPost && <GlobalTooltipComponent client:idle />}
    <PageLoadingIndicatorComponent client:idle />
    {isPost && <PhotoSwipeToolbarComponent client:idle />}
    {readingProgress && <ScrollTopButtonComponent client:idle />}
    {
      shouldLoadSpeedInsights && (
        <script
          defer
          src="/_vercel/speed-insights/script.js"
          data-sdkn="@vercel/speed-insights/astro"
          data-sdkv={speedInsightsVersion}
          data-route={speedInsightsRoute}
        />
      )
    }

    <script>
      import "@/assets/js/app-init.js";
    </script>
  </body>
</html>
