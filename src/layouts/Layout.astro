---
import { SEO, type Props as SEOProps } from "astro-seo";

import {
  SITE_DESCRIPTION,
  SITE_TAB_TITLE,
  SITE_TAB_ARTICLE
} from "@/consts";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface Props extends SEOProps {
  locale?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Extraction des props SEO
const {
  locale = "fr",
  title,
  description,
  ...seoRest
} = Astro.props as Props;

// Titre personnalisé : "ct-blog: <titre>" ou titre par défaut
const seoTitle = title
  ? `${SITE_TAB_ARTICLE} ${title}`
  : SITE_TAB_TITLE;

const seoDescription = description ?? SITE_DESCRIPTION;
---

<!doctype html>
<html lang={locale}>
  <head>
    <SEO
      title={seoTitle}
      description={seoDescription}
      charset="utf-8"
      canonical={canonicalURL}
      {...seoRest}
      extend={{
        meta: [
          { name: "viewport", content: "width=device-width,initial-scale=1" },
          { name: "generator", content: Astro.generator },
          ...(Astro.props.extend?.meta ?? [])
        ],
        link: [
          ...(Astro.props.extend?.link ?? []),
          { rel: "icon", type: "image/x-icon", href: "/favicon.ico" },
          {
            rel: "alternate",
            type: "application/rss+xml",
            title: SITE_TAB_TITLE,
            href: `${Astro.site}rss.xml`
          },
          { rel: "sitemap", href: "/sitemap-index.xml" }
        ]
      }}
    />

    <style is:global>
/* latin */
@font-face {
  font-family: 'Roboto Flex';
  font-style: normal;
  font-weight: 100 900;
  font-stretch: 100%;
  font-display: swap;
  src: url('/fonts/roboto-flex-v30-latin-regular.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
}

:root {
  font-family: "Roboto Flex", sans-serif;
  font-optical-sizing: auto;
}


/* roboto-mono-regular - latin */
@font-face {
  font-display: swap;
  font-family: 'Roboto Mono';
  font-style: normal;
  font-weight: 400;
  src: url('/fonts/roboto-mono-v31-latin-regular.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
    U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
    U+2212, U+2215, U+FEFF, U+FFFD;
}

/* roboto-mono-italic - latin */
@font-face {
  font-display: swap;
  font-family: 'Roboto Mono';
  font-style: italic;
  font-weight: 400;
  src: url('/fonts/roboto-mono-v31-latin-italic.woff2') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
    U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
    U+2212, U+2215, U+FEFF, U+FFFD;
}


      :root {
        font-family: "Roboto Flex", sans-serif;
        font-optical-sizing: auto;
      }

      code,
      pre,
      kbd,
      samp {
        font-family: "Roboto Mono", monospace;
      }

      /* Liens d’ancrage dans les titres */
      h1 > a.heading-link,
      h2 > a.heading-link,
      h3 > a.heading-link,
      h4 > a.heading-link,
      h5 > a.heading-link,
      h6 > a.heading-link {
        font: inherit;
        color: #000;
      }

      @media (prefers-color-scheme: dark) {
        h1 > a.heading-link,
        h2 > a.heading-link,
        h3 > a.heading-link,
        h4 > a.heading-link,
        h5 > a.heading-link,
        h6 > a.heading-link {
          font: inherit;
          color: #fff;
        }
      }
    </style>

    <slot name="head" />
  </head>

  <body
    class="bg-white text-slate-900 dark:bg-black dark:text-slate-100 leading-normal tracking-normal w-4/5 md:max-w-3xl mx-auto [&_a]:text-[#1565c0] dark:[&_a]:text-[#90caf9]"
  >
    <main class="container flex flex-col space-y-4 min-h-screen">
      <Header />
      <slot name="content" />
      <Footer />
    </main>
  </body>
</html>
