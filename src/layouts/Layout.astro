---
import {
  SITE_ARTICLE_TITLE_PREFIX,
  SITE_DESCRIPTION,
  SITE_DEFAULT_TITLE,
} from "@/site-config";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { CookieConsentBannerComponent } from "@/components/cookie-consent-banner.component";
import { CodeBlockEnhancerComponent } from "@/components/code-block-enhancer.component";
import { GlobalTooltipComponent } from "@/components/global-tooltip.component";
import { PageLoadingIndicatorComponent } from "@/components/page-loading-indicator.component";
import { PhotoSwipeToolbarComponent } from "@/components/photo-swipe-toolbar.component";
import { ScrollTopButtonComponent } from "@/components/scroll-top-button.component";
import Seo, { type OpenGraphData } from "@/components/SEO.astro";
import "@fontsource/material-icons";
import "@/assets/css/global.scss";

interface Props {
  locale?: string;
  title?: string;
  description?: string;
  bodyClass?: string;
  readingProgress?: boolean;
  openGraph?: OpenGraphData;
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const {
  locale = "fr",
  title,
  description,
  bodyClass,
  readingProgress = true,
  openGraph,
} = Astro.props as Props;

const seoTitle = title ? `${SITE_ARTICLE_TITLE_PREFIX} ${title}` : SITE_DEFAULT_TITLE;
const seoDescription = description ?? SITE_DESCRIPTION;
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      (() => {
        try {
          const key = "site_theme_preference";
          const stored = localStorage.getItem(key);
          const preference = ["system", "light", "dark"].includes(stored)
            ? stored
            : "system";
          const resolved =
            preference === "system"
              ? matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light"
              : preference;

          document.documentElement.dataset.theme = resolved;
          document.documentElement.dataset.themePreference = preference;
          document.documentElement.style.colorScheme = resolved;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_DEFAULT_TITLE}
      href={`${Astro.site}rss.xml`}
    />
    <Seo
      title={seoTitle}
      description={seoDescription}
      canonical={canonicalUrl}
      openGraph={openGraph}
    />

    <slot name="head" />
  </head>

  <body
    class:list={[bodyClass, { "reading-progress-disabled": !readingProgress }]}
    data-reading-progress={readingProgress ? "on" : "off"}
  >
    <main class="site-main">
      <Header />
      <slot name="content" />
    </main>
    <Footer />
    <CookieConsentBannerComponent client:load />
    <CodeBlockEnhancerComponent client:load />
    <GlobalTooltipComponent client:load />
    <PageLoadingIndicatorComponent client:load />
    <PhotoSwipeToolbarComponent client:load />
    <ScrollTopButtonComponent client:load />

    <script>
      import "@/assets/js/app-init.js";
    </script>
  </body>
</html>
