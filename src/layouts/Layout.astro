---
import { SITE_DESCRIPTION, SITE_TAB_TITLE, SITE_TAB_ARTICLE } from "@/consts";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { CookieConsentBannerComponent } from "@/components/CookieConsentBanner.component";
import SEO, { type Props as SEOProps } from "@/components/SEO.astro";
import "@/assets/css/global.css";

interface Props extends SEOProps {
  locale?: string;
  bodyClass?: string;
  scrollUi?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  locale = "fr",
  title,
  description,
  bodyClass,
  scrollUi = true,
  ...seoRest
} = Astro.props as Props;

const seoTitle = title ? `${SITE_TAB_ARTICLE} ${title}` : SITE_TAB_TITLE;
const seoDescription = description ?? SITE_DESCRIPTION;
---

<!doctype html>
<html lang={locale}>
  <head>
    <SEO
      title={seoTitle}
      description={seoDescription}
      charset="utf-8"
      canonical={canonicalURL}
      {...seoRest}
      extend={{
        meta: [
          { name: "viewport", content: "width=device-width,initial-scale=1,viewport-fit=cover" },
          { name: "generator", content: Astro.generator },
          ...(Astro.props.extend?.meta ?? []),
        ],
        link: [
          ...(Astro.props.extend?.link ?? []),
          { rel: "icon", type: "image/x-icon", href: "/favicon.ico" },
          {
            rel: "alternate",
            type: "application/rss+xml",
            title: SITE_TAB_TITLE,
            href: `${Astro.site}rss.xml`,
          },
        ],
      }}
    />

    <slot name="head" />
  </head>

  <body
    class:list={[bodyClass, { "page-no-scroll-ui": !scrollUi }]}
    data-scroll-ui={scrollUi ? "on" : "off"}
    data-scroll-progress-ui={scrollUi ? "on" : "off"}
    data-scroll-top-ui="on"
  >
    <main class="site-main">
      <Header />
      <slot name="content" />
    </main>
    <Footer />
    <CookieConsentBannerComponent client:load />

    <!-- Module applicatif packagé par Vite -->
    <script>
      import "@/assets/js/app-init.js";
    </script>
  </body>
</html>
