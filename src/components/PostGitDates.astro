---
interface Props {
  createdAt: Date | string;
  lastModified: Date | string;
}

const { createdAt, lastModified } = Astro.props as Props;

const formatter = new Intl.DateTimeFormat("fr-FR", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric",
});

function toDate(value: Date | string) {
  return value instanceof Date ? value : new Date(value);
}

function formatDate(value: Date | string) {
  const date = toDate(value);
  const formatted = formatter.format(date);
  return formatted.charAt(0).toUpperCase() + formatted.slice(1);
}

const createdLabel = "Création du post";
const modifiedLabel = "Dernière modification du post";
---

<footer class="post-git-dates" aria-label="Dates du post">
  <span class="post-git-date">
    <span
      class="post-icon-tooltip post-git-date__icon-trigger"
      tabindex="0"
      role="img"
      aria-label={createdLabel}
      data-tooltip={createdLabel}
    >
      <svg class="post-git-date__icon" viewBox="0 -960 960 960" aria-hidden="true" focusable="false">
        <path d="M440-120v-320H120v-80h320v-320h80v320h320v80H520v320h-80Z"></path>
      </svg>
    </span>
    <span class="post-git-date__text">
      <span class="post-git-date__label">Créé le :</span>
      <time datetime={toDate(createdAt).toISOString()}>{formatDate(createdAt)}</time>
    </span>
  </span>
  <span class="post-git-date-divider" aria-hidden="true"></span>
  <span class="post-git-date">
    <span
      class="post-icon-tooltip post-git-date__icon-trigger"
      tabindex="0"
      role="img"
      aria-label={modifiedLabel}
      data-tooltip={modifiedLabel}
    >
      <svg class="post-git-date__icon" viewBox="0 -960 960 960" aria-hidden="true" focusable="false">
        <path d="M200-200h57l391-391-57-57-391 391v57Zm-80 80v-170l528-527q12-11 26.5-17t30.5-6q16 0 31 6t26 18l55 56q12 11 17.5 26t5.5 30q0 16-5.5 30.5T817-647L290-120H120Zm640-584-56-56 56 56Zm-141 85-28-29 57 57-29-28Z"></path>
      </svg>
    </span>
    <span class="post-git-date__text">
      <span class="post-git-date__label">Modifié le :</span>
      <time datetime={toDate(lastModified).toISOString()}>{formatDate(lastModified)}</time>
    </span>
  </span>
</footer>
