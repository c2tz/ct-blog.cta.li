---
interface Props {
  createdAt: Date | string;
  createdCommit?: string;
  lastModified: Date | string;
  lastModifiedCommit?: string;
}

const { createdAt, createdCommit, lastModified, lastModifiedCommit } = Astro.props as Props;
const DISPLAY_TIME_ZONE = "Europe/Paris";
const GITHUB_REPOSITORY_URL = "https://github.com/c2tz/ct-blog.cta.li";

const formatter = new Intl.DateTimeFormat("fr-FR", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric",
  timeZone: DISPLAY_TIME_ZONE,
});

const timeFormatter = new Intl.DateTimeFormat("fr-FR", {
  hour: "2-digit",
  minute: "2-digit",
  hourCycle: "h23",
  timeZoneName: "shortOffset",
  timeZone: DISPLAY_TIME_ZONE,
});

function toDate(value: Date | string) {
  return value instanceof Date ? value : new Date(value);
}

function formatDate(value: Date | string) {
  const date = toDate(value);
  const formatted = formatter.format(date);
  return formatted.charAt(0).toUpperCase() + formatted.slice(1);
}

function formatNumericDate(value: Date | string) {
  return new Intl.DateTimeFormat("fr-FR", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    timeZone: DISPLAY_TIME_ZONE,
  }).format(toDate(value));
}

function formatTime(value: Date | string) {
  return timeFormatter
    .format(toDate(value))
    .replace(/\s?UTC$/, " UTC+0")
    .replace("UTC−", "UTC-");
}

function formatDateTime(value: Date | string) {
  return `${formatDate(value)}, ${formatTime(value)}`;
}

const createdLabel = "Création du post";
const modifiedLabel = "Dernière modification du post";
const shortCommit = (commit: string) => commit.slice(0, 7);
const createdCommitLabel = createdCommit
  ? `Commit de création : ${shortCommit(createdCommit)}`
  : undefined;
const modifiedCommitLabel = lastModifiedCommit
  ? `Commit de modification : ${shortCommit(lastModifiedCommit)}`
  : undefined;
const createdCommitUrl = createdCommit
  ? `${GITHUB_REPOSITORY_URL}/commit/${createdCommit}`
  : undefined;
const modifiedCommitUrl = lastModifiedCommit
  ? `${GITHUB_REPOSITORY_URL}/commit/${lastModifiedCommit}`
  : undefined;
---

<footer class="post-git-dates" aria-label="Dates du post">
  <span class="post-git-date">
    <span
      class="post-icon-tooltip post-git-date__icon-trigger"
      tabindex="0"
      role="img"
      aria-label={createdLabel}
      data-tooltip={createdLabel}
    >
      <span class="material-icons post-git-date__icon" aria-hidden="true">note_add</span>
    </span>
    <span class="post-git-date__text">
      <span class="post-git-date__label">Créé le :</span>
      <time datetime={toDate(createdAt).toISOString()}>{formatNumericDate(createdAt)}</time>
    </span>
    {createdCommitLabel && createdCommitUrl && (
      <a
        class="post-icon-tooltip post-git-commit__link"
        href={createdCommitUrl}
        aria-label={createdCommitLabel}
        data-tooltip={createdCommitLabel}
      >
        <span class="material-icons post-git-commit__icon" aria-hidden="true">commit</span>
      </a>
    )}
  </span>
  <span class="post-git-date-divider" aria-hidden="true"></span>
  <span class="post-git-date">
    <span
      class="post-icon-tooltip post-git-date__icon-trigger"
      tabindex="0"
      role="img"
      aria-label={modifiedLabel}
      data-tooltip={modifiedLabel}
    >
      <span class="material-icons post-git-date__icon" aria-hidden="true">edit_document</span>
    </span>
    <span class="post-git-date__text">
      <span class="post-git-date__label">Modifié le :</span>
      <time datetime={toDate(lastModified).toISOString()}>{formatDateTime(lastModified)}</time>
    </span>
    {modifiedCommitLabel && modifiedCommitUrl && (
      <a
        class="post-icon-tooltip post-git-commit__link"
        href={modifiedCommitUrl}
        aria-label={modifiedCommitLabel}
        data-tooltip={modifiedCommitLabel}
      >
        <span class="material-icons post-git-commit__icon" aria-hidden="true">commit</span>
      </a>
    )}
  </span>
</footer>
