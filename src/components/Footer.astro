---
import { SITE_TITLE } from "@/site-config";

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <a href="/" class="site-footer-logo" aria-label={`Accueil de ${SITE_TITLE}`}>
    <img
      src="/mask.webp"
      alt="Logo de c2tz"
      width="60"
      height="60"
      loading="eager"
      decoding="async"
      data-no-lightbox
    />
  </a>

  <nav aria-label="Liens externes">
    <ul class="site-footer-social-links">
      <li><a class="site-footer-link" href="https://bsky.app/profile/c2tz.bsky.social" target="_blank" rel="noopener noreferrer">Bluesky</a></li>
      <li><a class="site-footer-link" href="https://github.com/c2tz" target="_blank" rel="noopener noreferrer">GitHub</a></li>
      <li><a class="site-footer-link" href="https://www.komoot.com/fr-fr/user/1042380125464" target="_blank" rel="noopener noreferrer">Komoot</a></li>
      <li><a class="site-footer-link" href="https://matrix.to/#/@c2tz:matrix.org" target="_blank" rel="noopener noreferrer">Matrix</a></li>
      <li><a class="site-footer-link" href="https://youtube.com/@c2tz" target="_blank" rel="noopener noreferrer">YouTube</a></li>
      <li><a class="site-footer-link" href="https://blog.cta.li/" target="_blank" rel="noopener noreferrer">Blog</a></li>
      <li><a class="site-footer-link" href="https://ct-nas.cta.li/" target="_blank" rel="noopener noreferrer">ct-nas</a></li>
      <li><a class="site-footer-link" href="mailto:contact@cta.li">E-mail</a></li>
      <li><a class="site-footer-link" href="/publickey.contact@cta.li-71584f1e017c181a059efc676491d5bd231fe4ed.asc">Clé PGP</a></li>
    </ul>
  </nav>

  <p class="site-footer-meta">
    <a
      class="site-footer-link"
      href="https://raw.githubusercontent.com/c2tz/ct-blog.cta.li/f82f66a1b4cbca57899d2bdf827e99001e37dda9/LICENSE"
      target="_blank"
      rel="noopener noreferrer"
    >MIT License</a>
    {currentYear} — <a href="/" class="site-footer-link">{SITE_TITLE}</a>

    <span id="ip-wrapper" hidden>
      <span class="site-footer-separator" aria-hidden="true">•</span>
      Votre IP : <strong id="client-ip">—</strong>
      (<span id="client-country">—</span>)
    </span>
  </p>

  <script>
    import "@/assets/js/ip-geolocation.js";
  </script>
</footer>
