---
import { HomeHeroActionsComponent } from "./home-hero-actions.component";
import { KonachanLoadingIndicatorComponent } from "@/components/konachan/konachan-loading-indicator.component";
import { KonachanRatingToggleComponent } from "@/components/konachan/konachan-rating-toggle.component";
import { KonachanRefreshButtonComponent } from "@/components/konachan/konachan-refresh-button.component";
import {
  SITE_COOKIE_NAMES,
  SITE_CACHE_NAMES,
  SITE_EVENTS,
  SITE_LEGACY_COOKIE_NAMES,
  SITE_LEGACY_STORAGE_KEYS,
  SITE_STORAGE_KEYS,
} from "@/lib/site-contracts";
import { SITE_TITLE } from "@/site-config";

interface Props {
  title?: string;
  lede?: string;
  primaryActionHref?: string;
  primaryActionLabel?: string;
  secondaryActionHref?: string;
  secondaryActionLabel?: string;
}

const {
  title = SITE_TITLE,
  lede = "Micro-récits, grandes émotions. Des textes courts pour lire entre deux.",
  primaryActionHref = "/tags/all/",
  primaryActionLabel = "Voir plus",
  secondaryActionHref = "https://www.cta.li",
  secondaryActionLabel = "À propos",
} = Astro.props;
const initialBackground = null;
const konachanClientConfig = {
  cacheName: SITE_CACHE_NAMES.homeKonachanBackgrounds,
  events: {
    explicitContentChange: SITE_EVENTS.explicitContentChange,
    ratingChange: SITE_EVENTS.konachanRatingChange,
    refreshRequest: SITE_EVENTS.konachanRefreshRequest,
    refreshState: SITE_EVENTS.konachanRefreshState,
  },
  explicitContentCookieName: SITE_COOKIE_NAMES.explicitContentAcknowledgement,
  explicitContentStorageKey: SITE_STORAGE_KEYS.explicitContentAcknowledgement,
  legacyRatingCookieName: SITE_LEGACY_COOKIE_NAMES.homeKonachanRatingPreference,
  legacyRatingStorageKey: SITE_LEGACY_STORAGE_KEYS.homeKonachanRatingPreference,
  legacyStorageKey: SITE_LEGACY_STORAGE_KEYS.homeKonachanBackgrounds,
  ratingCookieName: SITE_COOKIE_NAMES.homeKonachanRatingPreference,
  ratingStorageKey: SITE_STORAGE_KEYS.homeKonachanRatingPreference,
  storageKey: SITE_STORAGE_KEYS.homeKonachanBackgrounds,
};
const konachanClientConfigJson = JSON.stringify({
  initialBackground,
  konachanClientConfig,
}).replace(/</g, "\\u003c");
---

<section class="home-anime-landing" aria-labelledby="home-hero-title" aria-busy="false">
  <div
    class="home-anime-background"
    data-konachan-background
    data-konachan-current-url=""
    data-loaded="false"
    aria-hidden="true"
  >
    <img
      class="home-anime-background-image"
      data-konachan-background-image
      alt=""
      decoding="async"
    />
  </div>
  <KonachanLoadingIndicatorComponent client:idle />
  <KonachanRatingToggleComponent client:idle />

  <div class="home-hero-content">
    <h1 id="home-hero-title">{title}</h1>
    <p class="home-hero-lede">
      {lede}
    </p>
    <HomeHeroActionsComponent
      primaryActionHref={primaryActionHref}
      primaryActionLabel={primaryActionLabel}
      secondaryActionHref={secondaryActionHref}
      secondaryActionLabel={secondaryActionLabel}
    />
  </div>

  <aside class="home-anime-credit" data-konachan-credit>
    <a
      class="home-anime-credit-link"
      href="https://konachan.com"
      target="_blank"
      rel="noopener noreferrer"
      data-konachan-credit-link
      hidden
    >
      Voir la source
    </a>
    <KonachanRefreshButtonComponent client:idle />
  </aside>
</section>

<script type="application/json" id="home-konachan-config" set:html={konachanClientConfigJson}></script>

<script>
  import { initHomeKonachanBackgroundFromDocument } from "@/assets/js/app/home-konachan-background.js";

  initHomeKonachanBackgroundFromDocument();
</script>
