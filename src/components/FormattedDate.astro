---
interface Props {
  date: Date | string;
  label?: string;
  time?: string;
  utcDetails?: boolean;
}

const { date: rawDate, label, time, utcDetails = false } = Astro.props as Props;
const date = rawDate instanceof Date ? rawDate : new Date(rawDate);
const pad = (value: number) => String(value).padStart(2, "0");

// Formatage complet en français (jour + date longue)
const dateFrComplete = date.toLocaleDateString("fr-FR", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric"
});

const formattedDate = dateFrComplete.charAt(0).toUpperCase() + dateFrComplete.slice(1);
const formattedDateTime = time ? `${formattedDate}, ${time}` : formattedDate;
const localDatePart = [
  date.getFullYear(),
  pad(date.getMonth() + 1),
  pad(date.getDate()),
].join("-");
const dateTimeValue = time ? `${localDatePart}T${time}:00` : date.toISOString();
const utcIsoBasic = [
  date.getUTCFullYear(),
  pad(date.getUTCMonth() + 1),
  pad(date.getUTCDate()),
].join("") + `T${[
  pad(date.getUTCHours()),
  pad(date.getUTCMinutes()),
  pad(date.getUTCSeconds()),
].join("")}Z`;
const displayDateTime = utcDetails ? utcIsoBasic : formattedDateTime;
const tooltipLabel = label ? `${label} ${formattedDateTime}` : undefined;
const localTimeAttrs = utcDetails
  ? {
      "data-local-date-time": date.toISOString(),
      "data-local-date-format": "compact-tz",
    }
  : {};
---
{
  label ? (
    <span class="post-date post-date--labeled">
      <span
        class="post-icon-tooltip post-date__icon-trigger"
        tabindex="0"
        role="img"
        aria-label={tooltipLabel}
        data-tooltip={tooltipLabel}
      >
        <svg class="post-date__icon" viewBox="0 -960 960 960" aria-hidden="true" focusable="false">
          <path d="M260-160q-91 0-155.5-63T40-377q0-78 47-139t123-78q25-92 100-149t170-57q117 0 198.5 81.5T760-520q69 8 114.5 59.5T920-340q0 75-52.5 127.5T740-160H520q-33 0-56.5-23.5T440-240v-206l-64 62-56-56 160-160 160 160-56 56-64-62v206h220q42 0 71-29t29-71q0-42-29-71t-71-29h-60v-80q0-83-58.5-141.5T480-720q-83 0-141.5 58.5T280-520h-20q-58 0-99 41t-41 99q0 58 41 99t99 41h100v80H260Zm220-280Z"></path>
        </svg>
      </span>
      <time datetime={dateTimeValue}>
        {displayDateTime}
      </time>
    </span>
  ) : tooltipLabel ? (
    <time
      class="post-date site-tooltip"
      datetime={dateTimeValue}
      tabindex="0"
      data-tooltip={tooltipLabel}
      aria-label={tooltipLabel}
      {...localTimeAttrs}
    >
      {displayDateTime}
    </time>
  ) : (
    <time class="post-date" datetime={dateTimeValue} {...localTimeAttrs}>
      {displayDateTime}
    </time>
  )
}
