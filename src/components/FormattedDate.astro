---
interface Props {
  date: Date;
}

const { date } = Astro.props as Props;

// Formatage complet en français (jour + date longue)
const dateFrComplete = date.toLocaleDateString("fr-FR", {
  weekday: "short",
  year: "numeric",
  month: "short",
  day: "numeric"
});
---
<time class="post-date" datetime={date.toISOString()}>
 {dateFrComplete.charAt(0).toUpperCase() + dateFrComplete.slice(1)}
</time>
