---
import { formatFrenchDate, formatFrenchDateTime, toDate } from "@/lib/date-format.mjs";

interface Props {
  createdAt: Date | string;
  createdCommit?: string;
  lastModified: Date | string;
  lastModifiedCommit?: string;
}

const { createdAt, createdCommit, lastModified, lastModifiedCommit } = Astro.props as Props;
const GITHUB_REPOSITORY_URL = "https://github.com/c2tz/ct-blog.cta.li";

const createdLabel = "Création du post";
const modifiedLabel = "Dernière modification du post";
const shortCommit = (commit: string) => commit.slice(0, 7);
const createdCommitLabel = createdCommit
  ? `Commit de création : ${shortCommit(createdCommit)}`
  : undefined;
const modifiedCommitLabel = lastModifiedCommit
  ? `Commit de modification : ${shortCommit(lastModifiedCommit)}`
  : undefined;
const createdCommitUrl = createdCommit
  ? `${GITHUB_REPOSITORY_URL}/commit/${createdCommit}`
  : undefined;
const modifiedCommitUrl = lastModifiedCommit
  ? `${GITHUB_REPOSITORY_URL}/commit/${lastModifiedCommit}`
  : undefined;
const createdIso = toDate(createdAt).toISOString();
const modifiedIso = toDate(lastModified).toISOString();
const createdDateCompact = formatFrenchDate(createdAt);
const createdDateFull = formatFrenchDateTime(createdAt);
const modifiedDateCompact = formatFrenchDate(lastModified);
const modifiedDateFull = formatFrenchDateTime(lastModified);
---

<footer class="post-git-dates" aria-label="Dates du post" data-post-git-dates>
  <span class="post-git-date" data-post-git-date="created">
    <span
      class="post-icon-tooltip"
      role="img"
      aria-label={createdLabel}
      data-tooltip={createdLabel}
    >
      <span class="material-symbols-rounded post-git-date-icon" aria-hidden="true">&#xE89C;</span>
    </span>
    <span class="post-git-date-text">
      <span class="post-git-date-label">Créé le :</span>
      <time class="site-date-compact" datetime={createdIso}>{createdDateCompact}</time>
      <time class="site-date-full" datetime={createdIso}>{createdDateFull}</time>
    </span>
    {
      createdCommitLabel && createdCommitUrl && (
        <a
          class="post-icon-tooltip post-git-commit-link"
          href={createdCommitUrl}
          aria-label={createdCommitLabel}
          data-tooltip={createdCommitLabel}
        >
          <span class="material-symbols-rounded post-git-commit-icon" aria-hidden="true">
            &#xEAF5;
          </span>
        </a>
      )
    }
  </span>
  <span class="post-git-date-divider" aria-hidden="true"></span>
  <span class="post-git-date" data-post-git-date="modified">
    <span
      class="post-icon-tooltip"
      role="img"
      aria-label={modifiedLabel}
      data-tooltip={modifiedLabel}
    >
      <span class="material-symbols-rounded post-git-date-icon" aria-hidden="true">&#xF88C;</span>
    </span>
    <span class="post-git-date-text">
      <span class="post-git-date-label">Modifié le :</span>
      <time class="site-date-compact" datetime={modifiedIso}>{modifiedDateCompact}</time>
      <time class="site-date-full" datetime={modifiedIso}>{modifiedDateFull}</time>
    </span>
    {
      modifiedCommitLabel && modifiedCommitUrl && (
        <a
          class="post-icon-tooltip post-git-commit-link"
          href={modifiedCommitUrl}
          aria-label={modifiedCommitLabel}
          data-tooltip={modifiedCommitLabel}
        >
          <span class="material-symbols-rounded post-git-commit-icon" aria-hidden="true">
            &#xEAF5;
          </span>
        </a>
      )
    }
  </span>
</footer>

<script>
  const observedPostGitDates = new WeakMap();

  function syncPostGitDateLayout(container) {
    const created = container.querySelector('[data-post-git-date="created"]');
    const modified = container.querySelector('[data-post-git-date="modified"]');
    if (!(created instanceof HTMLElement) || !(modified instanceof HTMLElement)) return;

    const createdRect = created.getBoundingClientRect();
    const modifiedRect = modified.getBoundingClientRect();
    container.dataset.stacked = modifiedRect.top > createdRect.top + 1 ? "true" : "false";
  }

  function initPostGitDateLayout() {
    document.querySelectorAll("[data-post-git-dates]").forEach((container) => {
      if (!(container instanceof HTMLElement) || observedPostGitDates.has(container)) return;

      const sync = () => syncPostGitDateLayout(container);
      observedPostGitDates.set(container, sync);
      sync();

      if (typeof ResizeObserver === "undefined") {
        window.addEventListener("resize", sync, { passive: true });
        return;
      }

      const observer = new ResizeObserver(sync);
      observer.observe(container);
      for (const child of container.children) observer.observe(child);
    });
  }

  initPostGitDateLayout();
  document.addEventListener("astro:page-load", initPostGitDateLayout);
  document.addEventListener("home:detail-view-change", () => {
    requestAnimationFrame(() => {
      document.querySelectorAll("[data-post-git-dates]").forEach((container) => {
        if (container instanceof HTMLElement) syncPostGitDateLayout(container);
      });
    });
  });
</script>
