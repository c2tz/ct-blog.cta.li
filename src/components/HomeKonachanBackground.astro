---
import fallbackOne from "@/content/blog/images/konachan-396319.jpg";
import fallbackTwo from "@/content/blog/images/konachan-382339.jpg";

const fallbackImages = [fallbackOne.src, fallbackTwo.src];
---

<div class="home-anime-bg" aria-hidden="true">
  <div class="home-anime-bg__image" data-konachan-background></div>
</div>

<aside class="home-anime-credit" data-konachan-credit hidden>
  <span class="home-anime-credit__label">Image Konachan</span>
  <a
    class="home-anime-credit__link"
    href="https://konachan.com"
    target="_blank"
    rel="noopener noreferrer"
    data-konachan-credit-link
  >
    Voir la source
  </a>
</aside>

<script define:vars={{ fallbackImages }}>
  const TARGET_SELECTOR = "[data-konachan-background]";
  const CREDIT_SELECTOR = "[data-konachan-credit]";
  const CREDIT_LINK_SELECTOR = "[data-konachan-credit-link]";
  const MANIFEST_URL = "/konachan-backgrounds.json";
  const REFRESH_MS = 60_000;
  const FALLBACK_IMAGES = fallbackImages;

  const pickRandom = (items) => items[Math.floor(Math.random() * items.length)];

  function preload(url) {
    return new Promise((resolve, reject) => {
      const image = new Image();
      image.decoding = "async";
      image.onload = () => resolve(url);
      image.onerror = reject;
      image.src = url;
    });
  }

  async function readManifest() {
    const response = await fetch(MANIFEST_URL, {
      credentials: "same-origin",
      cache: "no-store",
    });

    if (!response.ok) throw new Error(`konachan_manifest_${response.status}`);
    const manifest = await response.json();
    return Array.isArray(manifest.images) ? manifest.images : [];
  }

  function formatCredit(image) {
    if (!image) return "Voir la source";

    const parts = [];
    if (image.author) parts.push(image.author);
    if (image.id) parts.push(`#${image.id}`);

    return parts.length > 0 ? parts.join(" · ") : "Voir la source";
  }

  function setCredit(image) {
    const credit = document.querySelector(CREDIT_SELECTOR);
    const link = document.querySelector(CREDIT_LINK_SELECTOR);
    if (!credit || !link) return;

    if (!image?.source) {
      credit.hidden = true;
      return;
    }

    link.href = image.source;
    link.textContent = formatCredit(image);
    link.dataset.tooltip = image.tags
      ? `Voir l'image sur Konachan : ${image.tags}`
      : "Voir l'image sur Konachan";
    credit.hidden = false;
  }

  async function setBackground(target, image) {
    const url = typeof image === "string" ? image : image?.url;
    if (!url) return;

    const loadedUrl = await preload(url);
    target.style.setProperty("--home-konachan-image", `url("${loadedUrl}")`);
    target.dataset.loaded = "true";
    setCredit(typeof image === "string" ? null : image);
  }

  function initKonachanBackground() {
    const target = document.querySelector(TARGET_SELECTOR);
    if (!target || !("style" in target) || target.dataset.ready === "true") return;

    target.dataset.ready = "true";
    let images = [];

    const rotate = async () => {
      const selected = pickRandom(images) || pickRandom(FALLBACK_IMAGES);
      if (!selected) return;

      try {
        await setBackground(target, selected);
      } catch {
        const fallback = pickRandom(FALLBACK_IMAGES);
        if (fallback && fallback !== selected) {
          await setBackground(target, fallback).catch(() => {});
        }
      }
    };

    readManifest()
      .then((items) => {
        images = items.filter((item) => typeof item?.url === "string" && item.url);
      })
      .catch(() => {
        images = [];
      })
      .finally(() => {
        rotate();
        window.setInterval(rotate, REFRESH_MS);
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initKonachanBackground, { once: true });
  } else {
    initKonachanBackground();
  }

  addEventListener("astro:page-load", initKonachanBackground);
</script>
