---
import { materialExamples } from "@/components/material-examples/registry";
import Layout from "@/layouts/site-layout.astro";
---

<Layout
  title="Angular Material components"
  description="Catalogue isole des composants Angular Material officiels."
  bodyClass="material-components-page"
  readingProgress={false}
>
  <Fragment slot="content">
    <section class="material-components-lab not-prose">
      <header class="material-components-lab__hero">
        <p>Angular Material</p>
        <h1>Component showcase</h1>
      </header>

      <nav class="material-components-index" aria-label="Composants Angular Material">
        {
          materialExamples.map((example) => (
            <a class="material-components-index__item" href={`/material-components/${example.slug}/`}>
              <span>{example.title}</span>
              <small>{example.example}</small>
              <code>{example.mdxImport}</code>
            </a>
          ))
        }
      </nav>
    </section>
  </Fragment>
</Layout>

<style is:global>
  .material-components-page .site-main {
    max-width: 1180px;
  }

  .material-components-lab {
    margin-block: 2rem 4rem;
    color: var(--site-text);
    font-family: Roboto, Arial, sans-serif;
  }

  .material-components-lab__hero {
    margin-block: 2rem;
  }

  .material-components-lab__hero p {
    margin: 0 0 0.35rem;
    color: var(--mat-sys-primary, #6750a4);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .material-components-lab__hero h1 {
    margin: 0;
    font-family: "Google Sans Flex", Roboto, Arial, sans-serif;
    font-size: clamp(2.4rem, 7vw, 4.25rem);
    line-height: 0.98;
  }

  .material-components-index {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 12px;
  }

  .material-components-index__item {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, var(--site-text) 14%, transparent);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    background: color-mix(in srgb, var(--site-surface) 94%, transparent);
  }

  .material-components-index__item:hover {
    border-color: var(--mat-sys-primary, #6750a4);
  }

  .material-components-index__item span {
    font-weight: 700;
  }

  .material-components-index__item small {
    color: var(--site-muted);
  }

  .material-components-index__item code {
    overflow-wrap: anywhere;
    font-size: 0.75rem;
  }
</style>
