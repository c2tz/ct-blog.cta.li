---
import Frame from "@/components/material-examples/material-example-frame.astro";
import AutocompleteExample from "@/components/material-examples/autocomplete/autocomplete.astro";
import BadgeExample from "@/components/material-examples/badge/badge.astro";
import BottomSheetExample from "@/components/material-examples/bottom-sheet/bottom-sheet.astro";
import ButtonExample from "@/components/material-examples/button/button.astro";
import ButtonToggleExample from "@/components/material-examples/button-toggle/button-toggle.astro";
import CardExample from "@/components/material-examples/card/card.astro";
import CheckboxExample from "@/components/material-examples/checkbox/checkbox.astro";
import ChipsExample from "@/components/material-examples/chips/chips.astro";
import CoreExample from "@/components/material-examples/core/core.astro";
import DatepickerExample from "@/components/material-examples/datepicker/datepicker.astro";
import DialogExample from "@/components/material-examples/dialog/dialog.astro";
import DividerExample from "@/components/material-examples/divider/divider.astro";
import ExpansionExample from "@/components/material-examples/expansion/expansion.astro";
import FormFieldExample from "@/components/material-examples/form-field/form-field.astro";
import GridListExample from "@/components/material-examples/grid-list/grid-list.astro";
import IconExample from "@/components/material-examples/icon/icon.astro";
import InputExample from "@/components/material-examples/input/input.astro";
import ListExample from "@/components/material-examples/list/list.astro";
import MenuExample from "@/components/material-examples/menu/menu.astro";
import PaginatorExample from "@/components/material-examples/paginator/paginator.astro";
import ProgressBarExample from "@/components/material-examples/progress-bar/progress-bar.astro";
import ProgressSpinnerExample from "@/components/material-examples/progress-spinner/progress-spinner.astro";
import RadioExample from "@/components/material-examples/radio/radio.astro";
import RippleExample from "@/components/material-examples/ripple/ripple.astro";
import SelectExample from "@/components/material-examples/select/select.astro";
import SidenavExample from "@/components/material-examples/sidenav/sidenav.astro";
import SlideToggleExample from "@/components/material-examples/slide-toggle/slide-toggle.astro";
import SliderExample from "@/components/material-examples/slider/slider.astro";
import SnackBarExample from "@/components/material-examples/snack-bar/snack-bar.astro";
import SortExample from "@/components/material-examples/sort/sort.astro";
import StepperExample from "@/components/material-examples/stepper/stepper.astro";
import TableExample from "@/components/material-examples/table/table.astro";
import TabsExample from "@/components/material-examples/tabs/tabs.astro";
import TimepickerExample from "@/components/material-examples/timepicker/timepicker.astro";
import ToolbarExample from "@/components/material-examples/toolbar/toolbar.astro";
import TooltipExample from "@/components/material-examples/tooltip/tooltip.astro";
import TreeExample from "@/components/material-examples/tree/tree.astro";
import { materialExamples } from "@/components/material-examples/registry";
import Layout from "@/layouts/site-layout.astro";

const componentMap = {
  autocomplete: AutocompleteExample,
  badge: BadgeExample,
  "bottom-sheet": BottomSheetExample,
  button: ButtonExample,
  "button-toggle": ButtonToggleExample,
  card: CardExample,
  checkbox: CheckboxExample,
  chips: ChipsExample,
  core: CoreExample,
  datepicker: DatepickerExample,
  dialog: DialogExample,
  divider: DividerExample,
  expansion: ExpansionExample,
  "form-field": FormFieldExample,
  "grid-list": GridListExample,
  icon: IconExample,
  input: InputExample,
  list: ListExample,
  menu: MenuExample,
  paginator: PaginatorExample,
  "progress-bar": ProgressBarExample,
  "progress-spinner": ProgressSpinnerExample,
  radio: RadioExample,
  ripple: RippleExample,
  select: SelectExample,
  sidenav: SidenavExample,
  "slide-toggle": SlideToggleExample,
  slider: SliderExample,
  "snack-bar": SnackBarExample,
  sort: SortExample,
  stepper: StepperExample,
  table: TableExample,
  tabs: TabsExample,
  timepicker: TimepickerExample,
  toolbar: ToolbarExample,
  tooltip: TooltipExample,
  tree: TreeExample,
};

export function getStaticPaths() {
  return materialExamples.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const Component = componentMap[entry.slug as keyof typeof componentMap];
---

<Layout
  title={`${entry.title} - Angular Material`}
  description={`Demo isolee du composant Angular Material officiel ${entry.title}.`}
  bodyClass="material-components-page"
  readingProgress={false}
>
  <Fragment slot="content">
    <section class="material-components-lab material-components-lab--single not-prose">
      <header class="material-components-lab__hero">
        <a href="/material-components/">Tous les composants</a>
        <p>Angular Material</p>
        <h1>{entry.title}</h1>
      </header>

      <Frame
        example={entry.example}
        importPath={entry.mdxImport}
        slug={entry.slug}
        title={entry.title}
      >
        <Component />
      </Frame>
    </section>
  </Fragment>
</Layout>

<style is:global>
  .material-components-page .site-main {
    max-width: 1180px;
  }

  .material-components-lab {
    margin-block: 2rem 4rem;
    color: var(--site-text);
    font-family: Roboto, Arial, sans-serif;
  }

  .material-components-lab *,
  .material-components-lab *::before,
  .material-components-lab *::after {
    box-sizing: border-box;
  }

  .material-components-lab :where(table, th, td) {
    border: 0;
  }

  .material-components-lab .mat-mdc-table :where(th, td) {
    padding: 0;
  }

  .material-components-lab img {
    max-width: 100%;
    margin: 0;
  }

  .material-components-lab__hero {
    margin-block: 2rem;
  }

  .material-components-lab__hero > a {
    display: inline-flex;
    margin-block-end: 1rem;
    color: inherit;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
  }

  .material-components-lab__hero > a:hover {
    color: var(--mat-sys-primary, #6750a4);
  }

  .material-components-lab__hero p {
    margin: 0 0 0.35rem;
    color: var(--mat-sys-primary, #6750a4);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .material-components-lab__hero h1 {
    margin: 0;
    font-family: "Google Sans Flex", Roboto, Arial, sans-serif;
    font-size: clamp(2.4rem, 7vw, 4.25rem);
    line-height: 0.98;
  }

  .material-components-lab--single {
    max-width: 820px;
  }

  .material-example {
    display: block;
    min-width: 0;
  }

  .material-example-frame__body > .material-example {
    width: 100%;
  }

  .material-example-frame__body :where(mat-form-field, .mat-mdc-form-field) {
    max-width: 100%;
  }

  .material-example-frame__body :where(.example-container, .example-full-width) {
    max-width: 100%;
  }

  .cdk-overlay-container {
    font-family: Roboto, Arial, sans-serif;
  }
</style>
