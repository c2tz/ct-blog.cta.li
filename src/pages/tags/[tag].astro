---
import FormattedDate from "@/components/FormattedDate.astro";
import Layout from "@/layouts/Layout.astro";
import { getContentEntryGitDates } from "@/lib/gitDates.mjs";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allPosts = (await getCollection("blog"))
    .map((post) => ({
      ...post,
      gitDates: getContentEntryGitDates("blog", post, {
        createdAt: post.data.createdAt,
        lastModified: post.data.lastModified ?? post.data.pubDate,
      }),
    }))
    .sort((b, a) => {
      const aCreated = new Date(a.gitDates.createdAt ?? a.data.pubDate).valueOf();
      const bCreated = new Date(b.gitDates.createdAt ?? b.data.pubDate).valueOf();
      return aCreated - bCreated;
    });

  const contentTags = [
    ...new Set(
      allPosts
        .flatMap((post) => post.data.tags)
        .filter((tag): tag is string => tag !== undefined && tag !== "all")
    ),
  ].sort();
  const uniqueTags = [
    "all",
    ...contentTags,
  ];

  return uniqueTags.map((tag) => {
    const filteredPosts =
      tag === "all"
        ? allPosts
        : allPosts.filter((post) => post.data.tags && post.data.tags.includes(tag));

    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`Posts with Tag "${tag}"`} bodyClass="tag-page" scrollUi={false}>
  <Fragment slot="content">
    <h1>Posts with Tag "{tag}"</h1>
    <ul class="tag-posts">
      {
        posts.map((post) => (
          <li class="tag-post">
            <FormattedDate date={post.gitDates.createdAt ?? post.data.pubDate} utcDetails />
            <span class="tag-separator" aria-hidden="true">—</span>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </li>
        ))
      }
    </ul>
  </Fragment>
</Layout>
