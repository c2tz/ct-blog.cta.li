---
import { TagPostsPaginatorComponent } from "@/components/tags/tag-posts-paginator.component";
import { TagPostsTableComponent } from "@/components/tags/tag-posts-table.component";
import Layout from "@/layouts/site-layout.astro";
import { formatFrenchDate, formatFrenchDateTime, toDate } from "@/lib/date-format.mjs";
import { getContentEntryGitDates } from "@/lib/git-dates.mjs";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allPosts = (await getCollection("blog"))
    .map((post) => ({
      ...post,
      gitDates: getContentEntryGitDates("blog", post),
    }))
    .sort(
      (a, b) => new Date(b.gitDates.createdAt).valueOf() - new Date(a.gitDates.createdAt).valueOf(),
    );

  const contentTags = [
    ...new Set(
      allPosts
        .flatMap((post) => post.data.tags)
        .filter((tag): tag is string => tag !== undefined && tag !== "all"),
    ),
  ].sort();
  const uniqueTags = ["all", ...contentTags];

  return uniqueTags.map((tag) => {
    const filteredPosts =
      tag === "all"
        ? allPosts
        : allPosts.filter((post) => post.data.tags && post.data.tags.includes(tag));

    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const tag = Astro.params.tag ?? "all";
const { posts } = Astro.props;
const tagPosts = posts.map((post) => ({
  createdIso: toDate(post.gitDates.createdAt).toISOString(),
  createdLabelCompact: formatFrenchDate(post.gitDates.createdAt),
  createdLabelFull: formatFrenchDateTime(post.gitDates.createdAt),
  title: post.data.title,
  url: `/posts/${post.id}/`,
}));
---

<Layout title={`Articles avec le tag « ${tag} »`} bodyClass="tag-page" readingProgress={false}>
  <Fragment slot="content">
    <section aria-labelledby="tag-posts-title">
      <h1 id="tag-posts-title">Articles avec le tag « {tag} »</h1>
      {
        tag === "all" ? (
          <TagPostsTableComponent client:load posts={tagPosts} tag={tag} />
        ) : (
          <TagPostsPaginatorComponent client:load posts={tagPosts} tag={tag} />
        )
      }
    </section>
  </Fragment>
</Layout>
