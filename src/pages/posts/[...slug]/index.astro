---
import { type CollectionEntry, getCollection, render } from "astro:content";

import { GiscusCommentsComponent } from "@/components/feedback/giscus-comments.component";
import PostGitDates from "@/components/post/post-git-dates.astro";
import Prose from "@/components/post/prose.astro";
import Layout from "@/layouts/site-layout.astro";
import { getContentEntryGitDates } from "@/lib/git-dates.mjs";
import { SITE_GISCUS_CONFIG } from "@/site-config";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
const gitDates = getContentEntryGitDates("blog", post);
const { createdAt, lastModified } = gitDates;
const postPriority = post.data.priority ?? 0;
const visiblePostTags = [...(post.data.tags ?? [])].filter((tag) => tag !== "all");
const postTags = ["all", ...visiblePostTags];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  openGraph={{
    title: post.data.title,
    type: "article",
    image: `${Astro.site}posts/${post.id}/og.png`,
    description: post.data.description,
    publishedTime: createdAt,
    modifiedTime: lastModified,
  }}
>
  <Fragment slot="content">
    <article class="post" data-pagefind-body>
      <header class="post-header">
        <h1 id="post-title" class="post-title-anchor" data-anchor-reset>
          {post.data.title}
        </h1>
      </header>
      <div class="post-search-metadata" data-pagefind-ignore aria-hidden="true">
        <time
          datetime={createdAt}
          data-pagefind-meta="created[datetime]"
          data-pagefind-sort="created[datetime]"
        >
          {createdAt}
        </time>
        <time
          datetime={lastModified}
          data-pagefind-meta="modified[datetime]"
          data-pagefind-sort="modified[datetime]"
        >
          {lastModified}
        </time>
        <span data-pagefind-meta="tags">
          {visiblePostTags.join(", ")}
        </span>
        <span data-pagefind-meta="priority">
          {postPriority}
        </span>
        {visiblePostTags.map((tag) => <span data-pagefind-filter="tag">{tag}</span>)}
      </div>
      <Prose>
        <Content />
      </Prose>
      <div data-pagefind-ignore>
        <PostGitDates
          createdAt={createdAt}
          createdCommit={gitDates.createdCommit}
          lastModified={lastModified}
          lastModifiedCommit={gitDates.lastModifiedCommit}
        />
      </div>
      <nav aria-label="Tags de l’article" data-pagefind-ignore>
        <ul class="post-tags">
          {
            postTags.map((tag) => (
              <li>
                <a href={`/tags/${tag}/`}>#{tag}</a>
              </li>
            ))
          }
        </ul>
      </nav>
      <GiscusCommentsComponent
        client:load
        repo={SITE_GISCUS_CONFIG.repo}
        repoId={SITE_GISCUS_CONFIG.repoId}
        category={SITE_GISCUS_CONFIG.category}
        categoryId={SITE_GISCUS_CONFIG.categoryId}
        mapping={SITE_GISCUS_CONFIG.mapping}
        strict={SITE_GISCUS_CONFIG.strict}
        reactionsEnabled={SITE_GISCUS_CONFIG.reactionsEnabled}
        emitMetadata={SITE_GISCUS_CONFIG.emitMetadata}
        inputPosition={SITE_GISCUS_CONFIG.inputPosition}
        lang={SITE_GISCUS_CONFIG.lang}
      />
    </article>
  </Fragment>
</Layout>
