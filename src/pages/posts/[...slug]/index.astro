---
import { type CollectionEntry, getCollection, render } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import PostGitDates from "@/components/PostGitDates.astro";
import Prose from "@/components/Prose.astro";
import { getContentEntryGitDates } from "@/lib/git-dates.mjs";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
const gitDates = getContentEntryGitDates("blog", post);
const { createdAt, lastModified } = gitDates;
const postTags = [
  "all",
  ...[...(post.data.tags ?? [])].filter((tag) => tag !== "all"),
];
---

<Layout
  title={post.data.title}
  description={post.data.description}
  openGraph={{
    title: post.data.title,
    type: "article",
    image: `${Astro.site}posts/${post.id}/og.png`,
    description: post.data.description,
    publishedTime: createdAt,
    modifiedTime: lastModified,
  }}
>
  <Fragment slot="content">
    <article class="post">
      <header class="post-header">
        <h1 id="post-title" class="post-title-anchor" data-anchor-reset>
          {post.data.title}
        </h1>
      </header>
      <Prose>
        <Content />
      </Prose>
      <PostGitDates
        createdAt={createdAt}
        createdCommit={gitDates.createdCommit}
        lastModified={lastModified}
        lastModifiedCommit={gitDates.lastModifiedCommit}
      />
      <nav aria-label="Tags de l’article">
        <ul class="post-tags">
          {
            postTags.map((tag) => (
              <li>
                <a href={`/tags/${tag}/`}>
                  #{tag}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </article>
  </Fragment>
</Layout>
