---
import { getCollection, getEntry } from "astro:content";

import HomeKonachanBackground from "@/components/home/home-konachan-background.astro";
import { HomeTagsTreeComponent } from "@/components/home/home-tags-tree.component";
import FormattedDate from "@/components/post/formatted-date.astro";
import Layout from "@/layouts/site-layout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/site-config";
import { getContentEntryGitDates } from "@/lib/git-dates.mjs";

const posts = (await getCollection("blog"))
  .map((post) => ({
    ...post,
    gitDates: getContentEntryGitDates("blog", post),
  }))
  .sort(
    (a, b) =>
      new Date(b.gitDates.createdAt).valueOf() -
      new Date(a.gitDates.createdAt).valueOf(),
  );

const latestPosts = posts.slice(0, 3);
const contentTags = [
  ...new Set(
    posts
      .flatMap((post) => post.data.tags)
      .filter((tag): tag is string => tag !== undefined && tag !== "all"),
  ),
].sort();
const uniqueTags = [
  "all",
  ...contentTags,
];
const intro = await getEntry("info", "intro");
const introData = intro?.data ?? {};
const homeCopy = {
  heroTitle: typeof introData.heroTitle === "string" ? introData.heroTitle : "Court Teplaye",
  heroLede:
    typeof introData.heroLede === "string"
      ? introData.heroLede
      : "Micro-récits, grandes émotions. Des textes courts pour lire entre deux.",
  primaryActionHref:
    typeof introData.primaryActionHref === "string" ? introData.primaryActionHref : "/tags/all/",
  primaryActionLabel:
    typeof introData.primaryActionLabel === "string" ? introData.primaryActionLabel : "Voir plus",
  secondaryActionHref:
    typeof introData.secondaryActionHref === "string"
      ? introData.secondaryActionHref
      : "https://www.cta.li",
  secondaryActionLabel:
    typeof introData.secondaryActionLabel === "string"
      ? introData.secondaryActionLabel
      : "À propos",
  latestPostsTitle:
    typeof introData.latestPostsTitle === "string" ? introData.latestPostsTitle : "Derniers articles",
  tagsTitle: typeof introData.tagsTitle === "string" ? introData.tagsTitle : "Tags",
};
---

<Layout
  bodyClass="home-page"
  readingProgress={false}
  openGraph={{
    title: SITE_TITLE,
    type: "website",
    image: `${Astro.site}og.png`,
    description: SITE_DESCRIPTION,
  }}
>
  <Fragment slot="content">
    <HomeKonachanBackground
      title={homeCopy.heroTitle}
      lede={homeCopy.heroLede}
      primaryActionHref={homeCopy.primaryActionHref}
      primaryActionLabel={homeCopy.primaryActionLabel}
      secondaryActionHref={homeCopy.secondaryActionHref}
      secondaryActionLabel={homeCopy.secondaryActionLabel}
    />

    <section class="home-section" aria-labelledby="blog-posts">
      <h2 id="blog-posts">
        <a href="#blog-posts" class="heading-link">{homeCopy.latestPostsTitle}</a>
      </h2>

      <ul class="home-posts">
        {
          latestPosts.map((post) => (
            <li class="home-post">
              <span class="home-post-date">
                <FormattedDate date={post.gitDates.createdAt} />
              </span>
              <span class="home-separator" aria-hidden="true">·</span>
              <a class="home-post-title" href={`/posts/${post.id}/`}>
                {post.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="home-section home-tags-section" aria-labelledby="tags">
      <HomeTagsTreeComponent client:visible title={homeCopy.tagsTitle} tags={uniqueTags} />
    </section>
  </Fragment>
</Layout>
