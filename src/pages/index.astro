---
import { getCollection } from "astro:content";

import Layout from "../layouts/Layout.astro";
import HomeKonachanBackground from "../components/HomeKonachanBackground.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts";
import { getContentEntryGitDates } from "@/lib/gitDates.mjs";

const posts = (await getCollection("blog"))
  .map((post) => ({
    ...post,
    gitDates: getContentEntryGitDates("blog", post, {
      createdAt: post.data.createdAt ?? post.data.pubDate,
      lastModified: post.data.lastModified ?? post.data.pubDate,
    }),
  }))
  .sort((b, a) => {
    const aCreated = new Date(a.gitDates.createdAt ?? a.data.pubDate).valueOf();
    const bCreated = new Date(b.gitDates.createdAt ?? b.data.pubDate).valueOf();
    return aCreated - bCreated;
  });

const uniqueTags = [
  ...new Set(
    posts.flatMap((post) => post.data.tags).filter((tag) => tag !== undefined),
  ),
].sort();
---

<Layout
  bodyClass="home-page"
  scrollUi={false}
  openGraph={{
    basic: {
      title: SITE_TITLE,
      type: "website",
      image: `${Astro.site}og.png`,
    },
    optional: {
      description: SITE_DESCRIPTION,
    },
  }}
>
  <Fragment slot="content">
    <HomeKonachanBackground />

    <section class="home-section home-section--posts" aria-labelledby="blog-posts">
      <h2 id="blog-posts">
        <a href="#blog-posts" class="heading-link" style="color:inherit"
          >Derniers articles</a
        >
      </h2>

      <ul class="home-posts">
        {
          posts.map((post) => (
            <li class="home-post">
              <FormattedDate date={post.gitDates.createdAt ?? post.data.pubDate} utcDetails />
              <span class="home-separator" aria-hidden="true">—</span>
              <a href={`/posts/${post.id}/`}>
                {post.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="home-section home-section--tags" aria-labelledby="tags">
      <h3 id="tags">
        <a href="#tags" class="heading-link" style="color:inherit">Tags</a>
      </h3>

      <ul class="home-tags">
        {
          uniqueTags.map((tag) => (
            <li>
              <a href={`/tags/${tag}/`}>
                #{tag}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Fragment>
</Layout>
