---
import { getCollection, getEntry } from "astro:content";

import { HomeDetailToggleComponent } from "@/components/home/home-detail-toggle.component";
import { HomeLatestPostsTableComponent } from "@/components/home/home-latest-posts-table.component";
import HomeKonachanBackground from "@/components/home/home-konachan-background.astro";
import { HomeSectionDividerComponent } from "@/components/home/home-section-divider.component";
import { HomeTagsTreeComponent } from "@/components/home/home-tags-tree.component";
import Layout from "@/layouts/site-layout.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "@/site-config";
import { formatFrenchDate, formatFrenchDateTime, toDate } from "@/lib/date-format.mjs";
import { getContentEntryGitDates } from "@/lib/git-dates.mjs";

const posts = (await getCollection("blog"))
  .map((post) => ({
    ...post,
    gitDates: getContentEntryGitDates("blog", post),
  }))
  .sort(
    (a, b) => new Date(b.gitDates.createdAt).valueOf() - new Date(a.gitDates.createdAt).valueOf(),
  );

const latestPosts = posts.slice(0, 3);
const latestPostSummaries = latestPosts.map((post) => ({
  dateCompact: formatFrenchDate(post.gitDates.createdAt),
  dateFull: formatFrenchDateTime(post.gitDates.createdAt),
  datetime: toDate(post.gitDates.createdAt).toISOString(),
  href: `/posts/${post.id}/`,
  title: post.data.title,
}));
const contentTags = [
  ...new Set(
    posts
      .flatMap((post) => post.data.tags)
      .filter((tag): tag is string => tag !== undefined && tag !== "all"),
  ),
].sort();
const uniqueTags = ["all", ...contentTags];
const intro = await getEntry("info", "intro");
const introData = intro?.data ?? {};
const homeCopy = {
  heroTitle: typeof introData.heroTitle === "string" ? introData.heroTitle : SITE_TITLE,
  heroLede: typeof introData.heroLede === "string" ? introData.heroLede : "Simple blog-note.",
  primaryActionHref:
    typeof introData.primaryActionHref === "string" ? introData.primaryActionHref : "/tags/all/",
  primaryActionLabel:
    typeof introData.primaryActionLabel === "string" ? introData.primaryActionLabel : "Voir plus",
  secondaryActionHref:
    typeof introData.secondaryActionHref === "string"
      ? introData.secondaryActionHref
      : "https://www.cta.li",
  secondaryActionLabel:
    typeof introData.secondaryActionLabel === "string"
      ? introData.secondaryActionLabel
      : "À propos",
  latestPostsTitle:
    typeof introData.latestPostsTitle === "string"
      ? introData.latestPostsTitle
      : "Derniers articles",
  tagsTitle: typeof introData.tagsTitle === "string" ? introData.tagsTitle : "Tags",
};
---

<Layout
  bodyClass="home-page"
  readingProgress={false}
  openGraph={{
    title: SITE_TITLE,
    type: "website",
    image: `${Astro.site}og.png`,
    description: SITE_DESCRIPTION,
  }}
>
  <Fragment slot="content">
    <HomeKonachanBackground
      title={homeCopy.heroTitle}
      lede={homeCopy.heroLede}
      primaryActionHref={homeCopy.primaryActionHref}
      primaryActionLabel={homeCopy.primaryActionLabel}
      secondaryActionHref={homeCopy.secondaryActionHref}
      secondaryActionLabel={homeCopy.secondaryActionLabel}
    />

    <section class="home-section" aria-labelledby="blog-posts">
      <HomeSectionDividerComponent />

      <h2 id="blog-posts">
        <a href="#blog-posts" class="heading-link">{homeCopy.latestPostsTitle}</a>
      </h2>

      <HomeLatestPostsTableComponent client:load posts={latestPostSummaries} />
    </section>

    <section class="home-section home-tags-section" aria-label={homeCopy.tagsTitle}>
      <HomeDetailToggleComponent client:load />

      <div id="home-tags-detail" class="home-tags-detail" aria-labelledby="tags">
        <h2 id="tags">
          <a href="#tags" class="heading-link">{homeCopy.tagsTitle}</a>
        </h2>

        <HomeTagsTreeComponent tags={uniqueTags} />
      </div>
    </section>
  </Fragment>
</Layout>
